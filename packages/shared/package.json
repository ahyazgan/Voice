{
  "name": "@voice/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@voice/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "@voice/source": "./src/types.ts",
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./schemas": {
      "@voice/source": "./src/schemas.ts",
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./providers": {
      "@voice/source": "./src/providers.ts",
      "types": "./dist/providers.d.ts",
      "default": "./dist/providers.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
