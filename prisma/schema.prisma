generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Debtor {
  id         String   @id @default(cuid())
  fullName   String
  phoneE164  String
  amountDue  Int
  currency   String   @default("TRY")
  dueDate    DateTime
  invoiceRef String?
  // Arama saati penceresi borçlunun yerel saatine göre hesaplanır.
  timezone   String   @default("Europe/Istanbul")
  // Kalıcı opt-out: WRONG_NUMBER sonrası veya manuel "beni arama" → asla aranmaz.
  doNotCall  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  calls Call[]
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

model Campaign {
  id        String         @id @default(cuid())
  name      String
  status    CampaignStatus @default(ACTIVE)
  createdAt DateTime       @default(now())

  calls Call[]
}

enum CallStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  SCHEDULED // pencere dışı/retry: delayed job olarak beklemede
  CANCELLED // kampanya iptali ile düşürüldü
  SKIPPED   // KVKK/doNotCall nedeniyle hiç aranmadı
}

enum CallOutcome {
  PROMISE_TO_PAY
  DISPUTE
  WRONG_NUMBER
  NO_ANSWER
  CALLBACK_REQUESTED
  ESCALATED_TO_HUMAN
  REFUSED
}

model Call {
  id          String       @id @default(cuid())
  campaignId  String
  debtorId    String
  status      CallStatus   @default(QUEUED)
  attempt     Int          @default(1)
  // Pencere/retry için planlanan zaman (gözlemlenebilirlik; delayed job ile eşlenir).
  scheduledFor DateTime?
  // Outcome denormu: retry kararını CallResult join'i olmadan sorgulamak için.
  // Kaynağı CallResult.outcome; finalize anında yazılır.
  outcome     CallOutcome?
  // Outcome-bazlı takip/tekrar aramaları bu zincirle izlenir (idempotency + raporlama).
  parentCallId String?
  startedAt   DateTime?
  endedAt     DateTime?
  durationSec Int?
  createdAt   DateTime     @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  debtor   Debtor   @relation(fields: [debtorId], references: [id], onDelete: Restrict)

  parent   Call?  @relation("CallFollowup", fields: [parentCallId], references: [id], onDelete: SetNull)
  children Call[] @relation("CallFollowup")

  result     CallResult?
  transcript TranscriptTurn[]

  // KVKK taciz sayımı + retry sorguları bu indeksten yararlanır.
  @@index([debtorId, createdAt])
  @@index([campaignId, status])
}

model CallResult {
  callId          String      @id
  outcome         CallOutcome
  promisedAmount  Int?
  promisedDate    DateTime?
  disputeReason   String?
  recordingUrl    String?

  // Maliyet
  costTRY         Int         @default(0)
  llmTokensIn     Int         @default(0)
  llmTokensOut   Int         @default(0)
  ttsChars        Int         @default(0)
  sttSec          Int         @default(0)
  telephonySec    Int         @default(0)

  // Kalite metrikleri (telemetry.finalize'dan)
  avgResponseMs   Int?
  p95ResponseMs   Int?
  bargeIns        Int         @default(0)

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)
}

model TranscriptTurn {
  id        String   @id @default(cuid())
  callId    String
  speaker   String
  text      String
  at        DateTime
  latencyMs Int?

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId, at])
}
