{
  "name": "@voice/voice-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "openai:test": "node --env-file=../../.env --import tsx scripts/test-openai-turn.ts",
    "tts:test": "node --env-file=../../.env --import tsx scripts/test-tts.ts"
  },
  "dependencies": {
    "@voice/shared": "workspace:*",
    "ws": "^8.18.0",
    "xstate": "^5.18.0",
    "pino": "^9.3.0",
    "openai": "^4.65.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
