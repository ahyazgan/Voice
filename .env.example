# --- Database ---
DATABASE_URL=postgresql://voice:voice@localhost:5432/collections_voice

# --- Redis / Queue ---
REDIS_URL=redis://localhost:6379

# --- Worker ---
# Worker'ın voice-service'i tetikleyeceği WS adresi.
VOICE_WS_URL=ws://localhost:8787
# Eşzamanlı arama sayısı (BullMQ concurrency).
WORKER_CONCURRENCY=4
# Bir aramanın azami süresi (ms). Aşılırsa worker WS'i kapatır.
CALL_TIMEOUT_MS=600000

# --- Voice service ---
VOICE_WS_PORT=8787
# Arama sonu finalize özetini buraya POST eder. Boşsa persist atlanır (smoke test için OK).
API_BASE_URL=http://localhost:4000

# Servis-içi paylaşılan sır: voice-service → API finalize çağrısını korur.
# API tarafındaki INTERNAL_API_SECRET ile AYNI olmalı. Boşsa (yalnızca dev)
# finalize endpoint'i korumasız kalır — production'da MUTLAKA güçlü bir değer ver.
INTERNAL_API_SECRET=

# Panel girişi (insan operatör). İkisi de boşsa panel auth KAPALI (yalnızca dev).
# PANEL_PASSWORD: operatörün gireceği parola. PANEL_AUTH_SECRET: token imza anahtarı (güçlü rastgele).
PANEL_PASSWORD=
PANEL_AUTH_SECRET=
PANEL_TOKEN_TTL_HOURS=12

# Faz 1 (önerilen başlangıç) = platform: Retell/Vapi ses akışını yürütür.
# Faz 2 = cascade: kendi STT/LLM/TTS orkestratörümüzü kullanırız.
VOICE_MODE=platform

# --- Providers (boş bırakılırsa mock kullanılır) ---
ORCHESTRATION_PROVIDER=mock     # mock | retell | vapi (Faz 1)
TELEPHONY_PROVIDER=mock          # Faz 2
STT_PROVIDER=mock                # Faz 2
TTS_PROVIDER=mock                # Faz 2 (TR için ElevenLabs Flash önerilir)
LLM_PROVIDER=mock                # Hız > boyut. Faz 2'de küçük/hızlı model seç.

# Sağlayıcı sırları (gerçek implementasyon eklendiğinde doldur)
# Retell (ORCHESTRATION_PROVIDER=retell): aramayı Retell yürütür, her tur
# Custom-LLM WS üzerinden buraya gelir.
#   1) Retell panelinde bir agent oluştur, "Custom LLM" seç.
#   2) llm_websocket_url'i şuna ayarla: wss://<voice-service-host>/llm-websocket/{call_id}
#      (yerel test için ngrok/cloudflared ile 8787'yi dışarı aç).
#   3) begin_message'ı BOŞ bırak; rıza anonsu retell_llm_dynamic_variables ile gelir.
#   4) RETELL_FROM_NUMBER = Retell'e bağlı giden numara (TR yerel olmalı — telnyx.ts notu).
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=
# Vapi (ORCHESTRATION_PROVIDER=vapi): Retell alternatifi. Custom-LLM modunda
# assistant'ın model.url'i şuna işaret eder: https://<host>/vapi-llm/{callId}/chat/completions
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini      # hız öncelikli; telefon konuşması için sweet spot
OPENAI_TEMPERATURE=0.55       # doğal Türkçe çeşitliliği (0.3 fazla robotikti)
# Ajan kimliği — insan gibi tanıtım için (prompt + rıza anonsunda kullanılır).
AGENT_NAME=Zeynep
COMPANY_NAME=işletmemiz
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
# ⚠️ Varsayılan voice ID (Rachel) İNGİLİZCE'dir — Türkçe için MUTLAKA değiştir!
# https://elevenlabs.io/app/voice-library → "Turkish" filtresi → telefonda dinle.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# multilingual_v2 Türkçe'de daha doğal (~2x yavaş). Gecikme sorunsa eleven_turbo_v2_5.
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.6
ELEVENLABS_SIMILARITY=0.7
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Telnyx (TELEPHONY_PROVIDER=telnyx ise gerekli — TR yerel hat doğrulanmadan kurma)
# Telnyx Media Streaming INBOUND'dur: Telnyx bizim voice-service'e bağlanır.
# TELNYX_MEDIA_WS_URL = bizim PUBLIC WSS base'imiz (placeCall buna
#   /telnyx-media/<callId> ekler). Yerel test için cloudflared/ngrok ile 8787'yi aç.
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_FROM_NUMBER=
TELNYX_MEDIA_WS_URL=wss://<voice-service-host>

# Deepgram (STT_PROVIDER=deepgram ise DEEPGRAM_API_KEY zorunlu — Faz 2 cascade)
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=tr
DEEPGRAM_ENDPOINTING_MS=550        # 300 TR için erkendi (cümle ortası duraksamada kesiyordu)
DEEPGRAM_UTTERANCE_END_MS=1000
# Müşteri cevap vermezse: bu ms sonra "Alo, orada mısınız?"; 2. sessizlikte kapanır.
SILENCE_PROMPT_MS=8000

# --- Maliyet (telemetry CostBreakdown için, TRY/birim) ---
# Hepsi 0 ise dakika maliyeti 0 raporlanır. Sağlayıcı faturalarından doldur.
COST_TELEPHONY_PER_MIN_TRY=0
COST_STT_PER_MIN_TRY=0
COST_TTS_PER_CHAR_TRY=0
COST_LLM_IN_PER_1K_TOK_TRY=0
COST_LLM_OUT_PER_1K_TOK_TRY=0

# --- Arama orkestrasyonu (TR yasal — hukukçuya doğrulat) ---
# Arama saati penceresi: pencere dışı aramalar düşürülmez, bir sonraki pencereye
# ZAMANLANIR. Saatler borçlunun timezone'unda değerlendirilir.
CALL_WINDOW_START=08:00
CALL_WINDOW_END=19:00
CALL_WINDOW_DAYS=1,2,3,4,5,6          # 1=Pzt … 7=Paz (Pazar yasak varsayımı)
CALL_DEFAULT_TIMEZONE=Europe/Istanbul
# Resmi/dini tatiller (bu günlerde arama yok). Dini bayramlar her yıl kaydığı için
# yıllık güncellenmeli. Örn: 2026-04-23,2026-05-01,2026-05-19
PUBLIC_HOLIDAYS=

# KVKK taciz sınırı: bir borçluya azami arama (geçici limitler yeniden zamanlanır).
MAX_CALLS_PER_DEBTOR_PER_DAY=1
MAX_CALLS_PER_DEBTOR_PER_WEEK=3
MAX_TOTAL_CALLS_PER_DEBTOR=0          # 0 = limitsiz

# Outcome-bazlı tekrar deneme (BullMQ teknik retry'dan ayrı):
RETRY_NO_ANSWER_DELAY_HOURS=4
MAX_NO_ANSWER_ATTEMPTS=3
PROMISE_FOLLOWUP_OFFSET_DAYS=1        # ödeme sözü tarihinden +N gün takip (0=kapalı)
RETRY_REFUSED_AFTER_DAYS=0           # 0 = REFUSED'da asla tekrar arama (ısrar=taciz)

# Hız limiti: CALL_RATE_DURATION_MS içinde en çok CALL_RATE_MAX arama işlenir.
CALL_RATE_MAX=10
CALL_RATE_DURATION_MS=60000

# --- KVKK ---
# Ses kaydı saklama rızası. GÜVENLİ varsayılan: false (kayıt URL'si saklanmaz).
# Rıza anonsu her aramada çalar; bu yalnızca kaydın SAKLANIP saklanmayacağını belirler.
# true yapmadan önce hukuki dayanağını netleştir (BTK + KVKK).
DEFAULT_RECORDING_CONSENT=false
# KVKK retention: süre dolunca ses kaydı (recordingUrl) ve transkript silinir.
RECORDING_RETENTION_DAYS=90
TRANSCRIPT_RETENTION_DAYS=365
# Retention tarayıcı aralığı (ms, varsayılan günde bir).
RETENTION_SWEEP_INTERVAL_MS=86400000
